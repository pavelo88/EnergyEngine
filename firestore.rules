rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. Funciones de Validación ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Obtiene los datos del documento del usuario usando su email como ID
    function userData() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data;
    }

    // Verifica si un rol existe dentro de la lista de roles del usuario
    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email)) &&
             role in userData().roles;
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superadmin');
    }

    // --- 2. Reglas por Colección ---

    // PERFIL DE USUARIO: Permite que el usuario lea su propia info al loguearse
    match /usuarios/{usuarioId} {
      allow read: if isSignedIn() && (request.auth.token.email == usuarioId || isAdmin());
      allow write: if isSignedIn() && (request.auth.token.email == usuarioId || isAdmin());
    }

    // CLIENTES Y TRABAJOS: Acceso general para usuarios logueados
    match /clientes/{clienteId} {
      allow read, write: if isSignedIn();
    }

    match /trabajos/{trabajoId} {
      allow read, write: if isSignedIn();
    }

    match /ordenes_trabajo/{ordenId} {
      allow read, write: if isSignedIn();
    }

    match /gastos/{gastoId} {
      allow read, write: if isSignedIn();
    }

    match /informes/{informeId} {
      allow read, write: if isSignedIn();
    }

    // CONTACTOS: Público para crear, privado para leer
    match /contactos/{contactoId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}