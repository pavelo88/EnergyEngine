
rules_version = '2'; 

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------------
    // Helper Functions
    // ------------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
             'admin' in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.roles;
    }

    function isInspector() {
       return exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
             'inspector' in get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.roles;
    }

    // ------------------------------------------------------------------------
    // Application Collections
    // ------------------------------------------------------------------------
    
    match /clientes/{clienteId} {
      allow read, write: if isSignedIn();
    }

    match /usuarios/{usuarioId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /trabajos/{trabajoId} {
      allow read, write: if isSignedIn();
    }

    match /gastos/{gastoId} {
      allow read, write: if isSignedIn();
    }

    match /contactos/{contactoId} {
      // Permitir creación pública desde el formulario web
      allow create: if true;
      // Lectura y gestión solo para administradores
      allow read, write: if isSignedIn() && isAdmin();
    }
  }
}
