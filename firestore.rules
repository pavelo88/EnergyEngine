rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- 1. Funciones de Validación ---
    
    function isSignedIn() {
      return request.auth != null;
    }
		
    function userData() {
      // Usamos 'in' para buscar de forma segura si el email existe en el token
      return (isSignedIn() && 'email' in request.auth.token) 
        ? get(/databases/$(database)/documents/usuarios/$(request.auth.token.email)).data 
        : {};
    }

    function hasRole(role) {
      return isSignedIn() && 
             'email' in request.auth.token &&
             exists(/databases/$(database)/documents/usuarios/$(request.auth.token.email)) &&
             role in userData().roles; // Aquí usamos userData() para quitar la advertencia
    }

    function isAdmin() {
      return hasRole('admin') || hasRole('superadmin');
    }

    // --- 2. Reglas por Colección ---

    match /usuarios/{usuarioId} {
      // Permite leer y crear para que el flujo anónimo funcione
      allow read, create: if isSignedIn(); 
      
      // Solo el dueño (con email vinculado) o el admin pueden actualizar
      allow update: if (isSignedIn() && request.auth.token.email == usuarioId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /clientes/{clienteId} { allow read, write: if isSignedIn(); }
    match /trabajos/{trabajoId} { allow read, write: if isSignedIn(); }
    match /ordenes_trabajo/{ordenId} { allow read, write: if isSignedIn(); }
    match /gastos/{gastoId} { allow read, write: if isSignedIn(); }
    match /informes/{informeId} { allow read, write: if isSignedIn(); }

    match /contactos/{contactoId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
  }
}